{
  "name": "FirstDay-HC",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "wdio": "wdio run ./wdio.conf.js",
    "remove-allure": "rm -rf allure-results && rm -rf allure-report",
    "downloadAppsPage": "rm -rf downloadApps && wdio run ./wdio.confWeb.js --suite downloadAppsPage",
    "androidLoginPage-FHDA": " wdio run ./wdio.confFHDA.js --suite androidLoginPage",
    "androidLoginPage-FHDC": "wdio run ./wdio.confFHDC.js --suite androidLoginPage",
    "androidMedicalRecordsPage": "wdio run ./wdio.confFHDC.js --suite androidMedicalRecordsModule",
    "androidAllScripts": "npm run remove-allure && npm run androidLoginPage-FHDA && npm run androidLoginPage-FHDC && npm run androidMedicalRecordsPage && npm run addAndVerifyContactUs_TrackerData",
    "androidContactUs_TrackerModule": "wdio run ./wdio.confFHDC.js --suite androidContactUs_TrackerModule",
    "iOSloginPage-FHDA": "wdio run ./wdio.confFHDAiOS.js --suite iOSLoginPageFHDA",
    "iOSloginPage-FHDC": "wdio run ./wdio.confFHDCiOS.js --suite iOSLoginPageFHDC",
    "iOSMedicalRecordsPage-FHDC": "wdio run ./wdio.confFHDCiOS.js --suite iOSMedicalRecordsModule",
    "iOSTrackerPage": "wdio run ./wdio.confFHDCiOS.js --suite iOSTrackerModule",
    "iOS_all_scripts": "npm run remove-allure && npm run iOSloginPage-FHDA && npm run iOSloginPage-FHDC && npm run iOSMedicalRecordsPage-FHDC && npm run addAndVerifyContactUs_Tracker_iOSData",
    "newCustomerPage_test": "set WEB_PROVIDER_URL=https://portal.test.firstdayhc.com/login && wdio run ./wdio.confWeb.js --suite customerPage",
    "contactUs_TrackerPage": "set WEB_PROVIDER_URL=https://portal.test.firstdayhc.com/login && wdio run ./wdio.confWeb.js --suite contactUs_TrackerPage",
    "contactUs_Tracker_iOSPage": "cross-env WEB_PROVIDER_URL=https://portal.test.firstdayhc.com/login wdio run ./wdio.confWeb.js --suite contactUs_Tracker_iOSPage",
    "addAndVerifyContactUs_TrackerData": "npm run androidContactUs_TrackerModule && npm run contactUs_TrackerPage",
    "addAndVerifyContactUs_Tracker_iOSData": "npm run iOSTrackerPage && npm run contactUs_Tracker_iOSPage",
    "webProviderPage_test": "set WEB_PROVIDER_URL=https://portal.test.firstdayhc.com/login && wdio run ./wdio.confWeb.js --suite webProviderPage",
    "webCaregiverPatientPage_test": "set WEB_PROVIDER_URL=https://portal.test.firstdayhc.com/login && wdio run ./wdio.confWeb.js --suite newCaregiverPatientPage",
    "webMasterMenuPage_test": "set WEB_PROVIDER_URL=https://portal.test.firstdayhc.com/login && wdio run ./wdio.confWeb.js --suite masterMenuPage",
    "webOtherProviderPage_test": "set WEB_PROVIDER_URL=https://portal.test.firstdayhc.com/login && wdio run ./wdio.confWeb.js --suite webOtherProviderPage",
    "allWebScripts": "npm run remove-allure && npm run newCustomerPage_test & npm run webProviderPage_test & npm run webMasterMenuPage_test & npm run webCaregiverPatientPage_test & npm run webOtherProviderPage_test",
    "allWebScripts_sequential": "npm run remove-allure && npm run newCustomerPage_test && npm run webProviderPage_test && npm run webMasterMenuPage_test && npm run webCaregiverPatientPage_test && npm run webOtherProviderPage_test",
    "allWebScripts_ci": "npm run remove-allure && npm run customerPage_ci && npm run caregiverPatientPage_ci && npm run masterMenuPage_ci && npm run providerPage_ci && npm run otherProviderPage_ci",
    "customerPage_ci": "wdio run ./wdio.confWeb.js --suite customerPage",
    "caregiverPatientPage_ci": "wdio run ./wdio.confWeb.js --suite newCaregiverPatientPage",
    "masterMenuPage_ci": "wdio run ./wdio.confWeb.js --suite masterMenuPage",
    "providerPage_ci": "wdio run ./wdio.confWeb.js --suite webProviderPage",
    "otherProviderPage_ci": "wdio run ./wdio.confWeb.js --suite webOtherProviderPage",
    "newCustomerPage_production": "set WEB_PROVIDER_URL=https://portal.firstdayhc.com/login && wdio run ./wdio.confWeb.js --suite customerPage",
    "webProviderPage_production": "set WEB_PROVIDER_URL=https://portal.firstdayhc.com/login && wdio run ./wdio.confWeb.js --suite webProviderPage",
    "webCaregiverPatientPage_production": "set WEB_PROVIDER_URL=https://portal.firstdayhc.com/login && wdio run ./wdio.confWeb.js --suite newCaregiverPatientPage",
    "webMasterMenuPage_production": "set WEB_PROVIDER_URL=https://portal.firstdayhc.com/login && wdio run ./wdio.confWeb.js --suite masterMenuPage",
    "webOtherProviderPage_production": "set WEB_PROVIDER_URL=https://portal.firstdayhc.com/login && wdio run ./wdio.confWeb.js --suite webOtherProviderPage",
    "allWebScripts_production": "npm run remove-allure && npm run newCustomerPage_production & npm run webProviderPage_production & npm run webMasterMenuPage_production & npm run webCaregiverPatientPage_production & npm run webOtherProviderPage_production"
  },
