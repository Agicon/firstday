    "cross-env": "^10.1.0",
    "del": "^6.1.1",
    "wdio-chromedriver-service": "^8.1.1"
  },
  "dependencies": {
    "appium-uiautomator2-driver": "^3.9.1",
    "exceljs": "^4.4.0",
